// Programa simples: soma dos primeiros N números
class Main {
    public static void main(String[] args){
        System.out.println(new Soma().calcular(10));
    }
}

class Soma {
    public int calcular(int n){
        int total ;
        int i ;
        total = 0 ;
        i = 1 ;
        while (i < n + 1) {
            total = total + i ;
            i = i + 1 ;
        }
        return total ;
    }
}
